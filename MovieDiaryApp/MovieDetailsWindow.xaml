<Window x:Class="MovieDiaryApp.MovieDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Movie Details"
        Height="600"
        Width="900"
        Background="#101820"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#2EC4C7"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#49D6D9"/>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#17212B"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1E2A36"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F5F7FA"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#B8C4CE"/>

        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Border Background="{StaticResource PanelBackgroundBrush}"
                CornerRadius="16"
                Padding="20">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Poster section -->
                <Border Grid.Column="0"
                        Background="{StaticResource CardBackgroundBrush}"
                        CornerRadius="14"
                        Padding="12">
                    <Border CornerRadius="10"
                            ClipToBounds="True">
                        <Image Source="{Binding PosterUrl}"
                               Stretch="Fill"
                               Height="420"/>
                    </Border>
                </Border>

                <!-- Details section -->
                <ScrollViewer Grid.Column="2"
                              VerticalScrollBarVisibility="Auto"
                              Background="Transparent">
                    <StackPanel>

                        <TextBlock Text="{Binding Title}"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,14"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <Border Background="{StaticResource CardBackgroundBrush}"
                                    CornerRadius="8"
                                    Padding="10,6"
                                    Margin="0,0,10,0">
                                <TextBlock Foreground="{StaticResource SecondaryTextBrush}"
                                           FontSize="13">
                                    <Run Text="Release: "/>
                                    <Run Text="{Binding ReleaseDate}"/>
                                </TextBlock>
                            </Border>

                            <Border Background="{StaticResource CardBackgroundBrush}"
                                    CornerRadius="8"
                                    Padding="10,6">
                                <TextBlock Foreground="{StaticResource AccentBrush}"
                                           FontSize="13"
                                           FontWeight="SemiBold">
                                    <Run Text="Rating: "/>
                                    <Run Text="{Binding Rating, StringFormat={}{0:F1}}"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>

                        <TextBlock Text="Overview"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   Margin="0,12,0,8"/>

                        <Border Background="{StaticResource CardBackgroundBrush}"
                                CornerRadius="12"
                                Padding="14">
                            <TextBlock Text="{Binding Overview}"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       FontSize="14"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                            <Button x:Name="WatchlistButton" 
                                    Content="Add to Watchlist"
                                    
                                    Height="40"
                                    Padding="14,8"
                                    Click="AddToWatchlist_Click"/>

                            <Button Content="Close"
                                    Width="100"
                                    Height="40"
                                    Margin="12,0,0,0"
                                    Background="#223140"
                                    Click="CloseButton_Click"/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>