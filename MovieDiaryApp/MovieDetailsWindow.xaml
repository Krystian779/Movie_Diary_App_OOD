<Window x:Class="MovieDiaryApp.MovieDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Movie Details" Height="500" Width="700"
        WindowStartupLocation="CenterOwner">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0"
                   Width="200"
                   Height="300"
                   Stretch="Uniform"
                   Source="{Binding PosterUrl}" />

            <StackPanel Grid.Column="1" Margin="20,0,0,0">
                <TextBlock Text="{Binding Title}"
                           FontSize="22"
                           FontWeight="Bold"
                           TextWrapping="Wrap"
                           Margin="0,0,0,10"/>

                <TextBlock FontSize="14" Margin="0,0,0,6">
                    <Run Text="Release Date: "/>
                    <Run Text="{Binding ReleaseDate}"/>
                </TextBlock>

                <TextBlock FontSize="14" Margin="0,0,0,15">
                    <Run Text="Rating: "/>
                    <Run Text="{Binding Rating}"/>
                </TextBlock>

                <TextBlock Text="Overview"
                           FontSize="16"
                           FontWeight="Bold"
                           Margin="0,0,0,8"/>

                <TextBlock Text="{Binding Overview}"
                           TextWrapping="Wrap"
                           FontSize="14"/>
                <Button Content="Add to Watchlist"
        Width="150"
        Height="35"
        Margin="0,15,0,0"
        Click="AddToWatchlist_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>