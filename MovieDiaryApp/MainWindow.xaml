<Window x:Class="MovieDiaryApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Movie Diary"
        Height="700"
        Width="1100"
        Background="#101820"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <!-- Main app colors -->
        <SolidColorBrush x:Key="AccentBrush" Color="#2EC4C7"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#49D6D9"/>
        <SolidColorBrush x:Key="MainBackgroundBrush" Color="#101820"/>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#17212B"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1E2A36"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F5F7FA"/>
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#B8C4CE"/>

        <!-- Button styling -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox styling -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#223140"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2EC4C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>

        <!-- Remove default harsh ListView look -->
        <Style TargetType="ListView">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource PanelBackgroundBrush}"
                CornerRadius="14"
                Padding="20"
                Margin="0,0,0,18">
            <StackPanel>
                <TextBlock Text="Movie Diary"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryTextBrush}"/>

                <TextBlock Text="Discover, search and save films in your own diary"
                           FontSize="14"
                           Margin="0,6,0,0"
                           Foreground="{StaticResource SecondaryTextBrush}"/>
            </StackPanel>
        </Border>

        <!-- Search / buttons area -->
        <Border Grid.Row="1"
                Background="{StaticResource PanelBackgroundBrush}"
                CornerRadius="14"
                Padding="16"
                Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Height="40"
                         VerticalContentAlignment="Center"/>

                <Button Grid.Column="1"
                        Content="Search"
                        Height="40"
                        Click="SearchButton_Click"/>

                <Button Grid.Column="2"
                        Content="Trending"
                        Height="40"
                        Click="TrendingButton_Click"/>

                <Button Grid.Column="3"
                        Content="Watchlist"
                        Height="40"
                        Margin="0"
                        Click="WatchlistButton_Click"/>
            </Grid>
        </Border>

        <!-- Movie cards -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      Background="Transparent">
            <ListView x:Name="MoviesListView"
                      ItemsSource="{Binding Movies}"
                      MouseDoubleClick="MoviesListView_MouseDoubleClick"
                      Background="Transparent"
                      BorderThickness="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Width="210"
                                Margin="0,0,18,18"
                                Padding="12"
                                Background="{StaticResource CardBackgroundBrush}"
                                CornerRadius="14">

                            <StackPanel>
                                <Border CornerRadius="10"
                                        ClipToBounds="True"
                                        Margin="0,0,0,12">
                                    <Image Source="{Binding PosterUrl}"
                                           Height="280"
                                           Stretch="Fill"/>
                                </Border>

                                <TextBlock Text="{Binding Title}"
                                           Foreground="{StaticResource PrimaryTextBrush}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           MaxHeight="44"/>

                                <TextBlock Text="{Binding ReleaseDate, StringFormat=Release: {0}}"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           FontSize="12"
                                           Margin="0,8,0,2"/>

                                <TextBlock Text="{Binding Rating, StringFormat=Rating: {0:F1}}"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="13"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>
    </Grid>
</Window>